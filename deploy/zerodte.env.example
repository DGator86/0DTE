# zerodte.env — environment for the shadow-mode service.
#
# Install to /etc/zerodte/zerodte.env, owned root:zerodte, mode 600:
#     sudo install -D -m 600 -o root -g zerodte deploy/zerodte.env.example \
#          /etc/zerodte/zerodte.env
#     sudo nano /etc/zerodte/zerodte.env      # fill in real values
#
# SECURITY: real keys live ONLY in this file on the VPS. Never commit a filled
# copy; this .example (placeholders only) is the only version in the repo.
# systemd reads values literally — do not quote them.

# --- Market-data feeds (required: at least ONE chain provider) --------------
# The service auto-detects whichever providers are credentialed and fails over
# between them per tick, in this priority order:
#     1. Tradier     (real-time NBBO + greeks; also the execution venue)
#     2. Tastytrade  (real-time NBBO + greeks via DXLink; OAuth2)
#     3. Massive     (greeks/OI, but NO real-time NBBO on the starter plan)
# Yahoo backstops bars / VIX / settlement for FREE with no credentials, so those
# never fail. Fill in the provider(s) you have below — set at least one.

# Tradier (recommended primary) ---
# NOTE: systemd's EnvironmentFile does NOT strip inline "# ..." comments (only
# whole-line comments) — anything after the value, including trailing spaces,
# becomes part of it. Keep comments on their own line, never on the value line.
# Sandbox host: https://sandbox.tradier.com/v1
TRADIER_ACCESS_TOKEN=replace-me
TRADIER_BASE_URL=https://api.tradier.com/v1

# Tastytrade (fallback) — create a personal OAuth grant for these ---
# Requires the `tastytrade` pip package (already in requirements.txt).
# TASTYTRADE_CLIENT_SECRET=replace-me
# TASTYTRADE_REFRESH_TOKEN=replace-me
# TASTYTRADE_TEST=1                              # optional: use the cert/sandbox env

# Massive (fallback; no real-time NBBO) ---
# MASSIVE_API_KEY=replace-me
# MASSIVE_BASE_URL=https://api.massive.com
# MASSIVE_AUTH=query                            # if you get a 401, key as query param

# --- Grok 4.5 autonomous PAPER trader (optional; OFF by default) -------------
# Create a project key at console.x.ai. Keep it only in this root-owned secrets
# file. The integration has no live-order adapter and refuses PAPER_ONLY=0.
#
# Safe rollout:
#   1) set XAI_API_KEY + GROK_ENABLED=1 while submission remains 0;
#   2) inspect grok_audit.sqlite / journalctl output;
#   3) set GROK_ORDER_SUBMISSION_ENABLED=1 for validated paper fills.
# XAI_API_KEY=replace-me
XAI_MODEL=grok-4.5
XAI_BASE_URL=https://api.x.ai/v1
GROK_ENABLED=0
GROK_ORDER_SUBMISSION_ENABLED=0
GROK_PAPER_ONLY=1
GROK_REASONING_EFFORT=high
GROK_BASE_INTERVAL_SECONDS=300
GROK_POSITION_INTERVAL_SECONDS=90
GROK_MIN_EVENT_GAP_SECONDS=45
GROK_EVENT_SPOT_MOVE_PCT=0.0015
GROK_MAX_TOOL_ROUNDS=5
GROK_MAX_OUTPUT_TOKENS=6000
GROK_MAX_DAILY_CYCLES=100
GROK_DAILY_SOFT_CAP_USD=5.00
GROK_DAILY_HARD_CAP_USD=8.00
GROK_MONTHLY_HARD_CAP_USD=170.00
GROK_MAX_RISK_FRACTION=0.05
GROK_MAX_REQUESTED_RISK_FRACTION=0.05
GROK_MAX_LEG_SPREAD_ABS=0.50
GROK_MAX_LEG_RELATIVE_SPREAD=0.75
GROK_MAX_QUOTE_AGE_SECONDS=15
GROK_ENTRY_START_HOUR=10
GROK_ENTRY_START_MINUTE=0
GROK_ENTRY_CUTOFF_HOUR=15
GROK_ENTRY_CUTOFF_MINUTE=15
# GROK_ALLOWED_SYMBOLS=SPY,XSP
# GROK_ALLOWED_FAMILIES=put_credit,call_credit,iron_condor,iron_fly,broken_wing,long_call,long_put,long_call_spread,long_put_spread
# GROK_AUDIT_DB=/var/lib/zerodte/grok_audit.sqlite
# Update only if xAI changes published prices; used for local cost estimates.
GROK_INPUT_PRICE_PER_MILLION=2.00
GROK_OUTPUT_PRICE_PER_MILLION=6.00

# --- Phone push for trade signals (recommended) -----------------------------
# Install the free "ntfy" app, then subscribe it to this exact topic string.
# Use a long random value so nobody else can guess your topic.
NOTIFY_NTFY_TOPIC=replace-with-a-long-random-string
# NOTIFY_NTFY_TOKEN=          # only if you make the topic private
# NOTIFY_COOLDOWN_MIN=15      # min minutes between pushes of the SAME ticket
#                             # (a persistent signal re-pings, not spams; 0 = every tick)

# --- Optional: email backend ------------------------------------------------
# NOTIFY_SMTP_HOST=smtp.gmail.com
# NOTIFY_SMTP_PORT=587
# NOTIFY_SMTP_USER=you@example.com
# NOTIFY_SMTP_PASS=app-password-not-your-login
# NOTIFY_EMAIL_TO=you@example.com

# --- Optional: append every ticket as JSON for later analysis ---------------
# NOTIFY_FILE=/var/lib/zerodte/tickets.jsonl

# --- Observability dashboard (read-only; phone/PC via Cloudflare Tunnel) ----
# Generate a long random string. Required to start zerodte-dashboard.service.
# DASHBOARD_TOKEN=replace-with-a-long-random-string
