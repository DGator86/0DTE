# Copy to .env (never commit .env). Used by run_0dte.sh on the VPS.
#
# REST API (options chain snapshot — required for live runs)
MASSIVE_API_KEY=
MASSIVE_BASE_URL=https://api.massive.com
MASSIVE_AUTH=bearer

# Optional: S3 flat files (not used by massive_feed.py REST adapter)
# MASSIVE_S3_ACCESS_KEY_ID=
# MASSIVE_S3_SECRET_ACCESS_KEY=
# MASSIVE_S3_ENDPOINT=https://files.massive.com
# MASSIVE_S3_BUCKET=flatfiles
#
# Tastytrade OAuth2 (order routing — optional)
# Create a grant once: developer.tastytrade.com → OAuth Applications → Manage → Create Grant
TASTYTRADE_CLIENT_ID=
TASTYTRADE_CLIENT_SECRET=
TASTYTRADE_REFRESH_TOKEN=
# TASTYTRADE_SCOPE="read trade openid"
# TASTYTRADE_REDIRECT_URI=http://localhost:8000
# TASTYTRADE_SANDBOX=0
#
# Tradier Brokerage API (market data + trading)
# Token from https://web.tradier.com/user/api
TRADIER_API_TOKEN=
TRADIER_ACCOUNT_ID=
# TRADIER_SANDBOX=0
