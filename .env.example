# Copy to .env (never commit .env). Used by run_0dte.sh on the VPS.
#
# REST API (options chain snapshot — required for live runs)
# Use either MASSIVE_API_KEY (dashboard API key) OR OAuth2 app credentials below.
MASSIVE_API_KEY=
MASSIVE_OAUTH_CLIENT_ID=
MASSIVE_OAUTH_CLIENT_SECRET=
# Optional: paste a dashboard-generated OAuth access token instead of client creds.
# MASSIVE_OAUTH_ACCESS_TOKEN=
# MASSIVE_OAUTH_TOKEN_URL=https://auth.massive.com/oauth2/token
MASSIVE_BASE_URL=https://api.massive.com
MASSIVE_AUTH=bearer

# Optional: S3 flat files (not used by massive_feed.py REST adapter)
# MASSIVE_S3_ACCESS_KEY_ID=
# MASSIVE_S3_SECRET_ACCESS_KEY=
# MASSIVE_S3_ENDPOINT=https://files.massive.com
# MASSIVE_S3_BUCKET=flatfiles
